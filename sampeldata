CREATE TABLE Students (
    StudentId INT IDENTITY(1,1) PRIMARY KEY,
    Name NVARCHAR(100),
    Email NVARCHAR(100),
    Age INT
);





CREATE PROCEDURE sp_AddStudent
    @Name NVARCHAR(100),
    @Email NVARCHAR(100),
    @Age INT
AS
BEGIN
    INSERT INTO Students (Name, Email, Age)
    VALUES (@Name, @Email, @Age);
END;



CREATE PROCEDURE sp_GetStudents
AS
BEGIN
    SELECT * FROM Students;
END;



